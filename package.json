{
  "name": "personal-cloud-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "corepack pnpm --filter web --filter @pcp/auth-service --filter @pcp/workspace-service --filter @pcp/runtime-service --filter @pcp/agent-service --filter @pcp/memory-service --filter @pcp/publish-service --filter @pcp/browser-service --parallel dev",
    "build": "corepack pnpm --filter web --filter @pcp/db --filter @pcp/auth-service --filter @pcp/workspace-service --filter @pcp/runtime-service --filter @pcp/agent-service --filter @pcp/memory-service --filter @pcp/publish-service --filter @pcp/browser-service build",
    "lint": "corepack pnpm --filter web --filter @pcp/db lint",
    "test": "corepack pnpm --filter web --filter @pcp/auth-service --filter @pcp/workspace-service --filter @pcp/runtime-service --filter @pcp/agent-service --filter @pcp/memory-service --filter @pcp/publish-service --filter @pcp/browser-service test",
    "typecheck": "corepack pnpm --filter web --filter @pcp/db --filter @pcp/shared --filter @pcp/auth-service --filter @pcp/workspace-service --filter @pcp/runtime-service --filter @pcp/agent-service --filter @pcp/memory-service --filter @pcp/publish-service --filter @pcp/browser-service typecheck",
    "smoke:local": "node scripts/baseline-smoke.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "infra:up": "cd infra/docker && docker compose up -d",
    "infra:down": "cd infra/docker && docker compose down",
    "infra:logs": "cd infra/docker && docker compose logs -f",
    "db:migrate": "pnpm --filter @pcp/db migrate",
    "db:seed": "pnpm --filter @pcp/db seed"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "playwright": "^1.59.1",
    "prettier": "^3.2.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
