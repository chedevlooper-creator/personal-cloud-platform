# PostgreSQL
POSTGRES_USER=pcp
POSTGRES_PASSWORD=pcp_dev_password
POSTGRES_DB=pcp

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# App
DATABASE_URL=postgresql://pcp:pcp_dev_password@localhost:5432/pcp
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=pcp-workspace
S3_REGION=us-east-1
SMTP_HOST=localhost
SMTP_PORT=1025

# Auth
COOKIE_SECRET=dev-cookie-secret-local-only-0000000000
SESSION_SECRET=dev-cookie-secret-local-only-0000000000
ENCRYPTION_KEY=dev-encryption-key-32-byte-local
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/oauth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/oauth/google/callback

# LLM Providers
LLM_PROVIDER=minimax
MINIMAX_TOKEN_PLAN_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.7
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Frontend service URLs
NEXT_PUBLIC_AUTH_API_URL=http://localhost:3001/auth
NEXT_PUBLIC_WORKSPACE_API_URL=http://localhost:3002/api
NEXT_PUBLIC_RUNTIME_API_URL=http://localhost:3003/api
NEXT_PUBLIC_AGENT_API_URL=http://localhost:3004/api
NEXT_PUBLIC_PUBLISH_API_URL=http://localhost:3006/publish
NEXT_PUBLIC_DEFAULT_MODEL=MiniMax-M2.7
NEXT_PUBLIC_PLAN_LABEL=Token Plan
